{
  "colors": {
    "primary": "#6366f1",
    "secondary": "#8b5cf6",
    "background": "#0a0a0f",
    "surface": "#1a1a2e",
    "text": "#e2e8f0",
    "accent": "#22d3ee",
    "error": "#ef4444",
    "success": "#22c55e",
    "border": "#2a2a4a"
  },
  "typography": {
    "fontFamilySans": "var(--font-geist-sans), system-ui, sans-serif",
    "fontFamilyMono": "var(--font-geist-mono), monospace",
    "baseSizePx": 16,
    "scaleRatio": 1.25,
    "weightNormal": 400,
    "weightMedium": 500,
    "weightBold": 700,
    "lineHeightTight": 1.2,
    "lineHeightNormal": 1.5,
    "lineHeightRelaxed": 1.75,
    "letterSpacingTight": "-0.025em",
    "letterSpacingNormal": "0em",
    "letterSpacingWide": "0.05em"
  },
  "spacing": {
    "baseUnitPx": 4,
    "xs": 1,
    "sm": 2,
    "md": 4,
    "lg": 8,
    "xl": 16
  },
  "radii": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "16px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 4px 6px rgba(0,0,0,0.4)",
    "lg": "0 10px 15px rgba(0,0,0,0.5)",
    "glow": "0 0 20px rgba(99,102,241,0.4)"
  },
  "animation": {
    "durationFast": "150ms",
    "durationNormal": "300ms",
    "durationSlow": "500ms",
    "easingDefault": "cubic-bezier(0.4, 0, 0.2, 1)",
    "easingSpring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "hoverScale": 1.05,
    "pressScale": 0.95,
    "scrollSmoothing": 0.1
  },
  "rive": {
    "button": {
      "hoverSpeed": 1,
      "pressScale": 0.95,
      "idleAmplitude": 0.5,
      "color": "#6366f1"
    },
    "icon": {
      "animationSpeed": 1,
      "color": "#22d3ee"
    },
    "loader": {
      "speed": 1,
      "color": "#8b5cf6"
    }
  }
}
